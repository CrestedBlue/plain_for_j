# plan_for_j v2 백엔드 환경변수 (복사 → .env). 실제 .env는 커밋 금지.

# --- 서버 ---
APP_PORT=8080

# --- MySQL ---
DB_HOST=127.0.0.1
DB_PORT=3307   # deploy/docker-compose.yml 가 호스트 3307로 매핑(로컬 3306 충돌 회피)
DB_USER=planforj
DB_PASSWORD=planforj
DB_NAME=planforj

# --- JWT (P2) ---
JWT_SECRET=change-me-to-a-long-random-string

# --- 소셜 OAuth (P2) — 서버에만 보관, 프론트 노출 금지 ---
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URL=http://localhost:8080/api/auth/kakao/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/google/callback

# --- 네이버 지역검색 (P3) — 서버에만 보관 ---
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=
